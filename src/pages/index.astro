---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import HomeHeroImage from '../assets/home-hero.jpg';
---
<!doctype html>
<html lang="en">
<head>
<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />
<main>
<h1>Single-origin matcha, sourced directly from Japan</h1>
<Image src={HomeHeroImage} alt="Matcha powder in a white bowl" width="1020" height="510" style="border-radius: 12px; margin: 1.5em 0;" />
<p>
West Matcha brings authentic, single-origin ceremonial-grade matcha to Canada — sourced
directly from tea-growing regions in Japan, including Nishio in Aichi Prefecture.
</p>
<p>
No blends, no shortcuts. Just matcha you can trace back to the place it was grown.
Read our <a href="/blog">blog</a> to learn about single-origin matcha, how it's made,
and why it tastes the way it does.
</p>
<p>
Want to know more about why we started this? Read <a href="/blog/founder-story">our story</a>.
</p>
</main>
<Footer />
</body>
</html>